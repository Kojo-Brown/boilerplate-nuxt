# PostgreSQL connection URL (Nuxt reads runtimeConfig.databaseUrl via NUXT_DATABASE_URL)
NUXT_DATABASE_URL=postgresql://user:password@localhost:5432/boilerplate_nuxt

# Session encryption key — must be at least 32 characters
NUXT_SESSION_PASSWORD=your-super-secret-session-password-at-least-32-chars

# GitHub OAuth app credentials
# Create an app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/auth/github
NUXT_OAUTH_GITHUB_CLIENT_ID=your_github_client_id
NUXT_OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret

# AWS S3 (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=your_s3_bucket_name
